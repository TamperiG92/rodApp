<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RodApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/cyan_primary</item>
        <item name="colorOnPrimary">@color/black_background</item>
        <item name="android:windowBackground">@color/black_background</item>
        <item name="android:colorBackground">@color/black_background</item>
        <item name="android:statusBarColor">@color/black_background</item>
        <item name="android:navigationBarColor">@color/black_background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_light</item>
        <item name="colorOutline">@color/surface_stroke</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_light</item>
        <item name="android:textColorSecondary">@color/text_gray</item>
    </style>

    <style name="Theme.RodApp" parent="Base.Theme.RodApp" />

    <style name="Theme.RodApp.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <style name="Theme.RodApp.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!-- Section Header Style -->
    <style name="SectionHeaderStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
