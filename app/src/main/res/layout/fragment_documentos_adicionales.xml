<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <ImageButton
                android:id="@+id/btn_back_docs_adic"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_back_desc"
                android:src="@android:drawable/ic_menu_revert"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/title_docs_adic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_docs_adicionales"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/btn_back_docs_adic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/btn_back_docs_adic" />

            <TextView
                android:id="@+id/lbl_registrar_docs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="@string/label_registrar_documentos"
                android:textColor="@color/button_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/title_docs_adic" />

            <TextView
                android:id="@+id/subtitle_docs_adic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/label_docs_adicionales_desc"
                android:textColor="@color/gris_hint"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lbl_registrar_docs" />

            <!-- Licencia de Conducción -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_licencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/dark_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_stroke"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@+id/subtitle_docs_adic">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/icon_licencia"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/texto_usuario"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/button_blue"
                        android:contentDescription="@null" />
                    <TextView
                        android:id="@+id/lbl_licencia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/label_licencia_conduccion"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_licencia"
                        app:layout_constraintTop_toTopOf="@+id/icon_licencia" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_permiso_conducir_desc"
                        android:textColor="@color/gris_hint"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/lbl_licencia"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_licencia" />
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/button_blue"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="20dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@android:color/transparent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seguro Todo Riesgo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_todo_riesgo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/dark_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_stroke"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@+id/card_licencia">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/icon_todo_riesgo"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/texto_usuario"
                        android:padding="12dp"
                        android:src="@android:drawable/checkbox_on_background"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/button_blue"
                        android:contentDescription="@null" />
                    <TextView
                        android:id="@+id/lbl_todo_riesgo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/label_seguro_todo_riesgo"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_todo_riesgo"
                        app:layout_constraintTop_toTopOf="@+id/icon_todo_riesgo" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_todo_riesgo_desc"
                        android:textColor="@color/gris_hint"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/lbl_todo_riesgo"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_todo_riesgo" />
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/button_blue"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="20dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@android:color/transparent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_crear_doc_personalizado"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="40dp"
                android:text="@string/btn_doc_personalizado"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:icon="@android:drawable/ic_menu_add"
                app:iconTint="@color/black"
                app:iconGravity="textStart"
                app:backgroundTint="@color/button_blue"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@+id/card_todo_riesgo" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/label_doc_personalizado_desc"
                android:textColor="@color/gris_hint"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_crear_doc_personalizado" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
