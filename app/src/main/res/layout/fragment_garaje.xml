<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue"
    tools:context=".fragments.GarajeFragment">

    <TextView
        android:id="@+id/title_garaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Mi Garaje"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subtitle_garaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestiona tus motocicletas"
        android:textColor="@color/gris_hint"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@+id/title_garaje"
        app:layout_constraintTop_toBottomOf="@+id/title_garaje" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_moto_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/dark_blue"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@+id/subtitle_garaje">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/img_moto"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circulo_oscuro"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/button_blue"
                android:contentDescription="Foto de la moto" />

            <TextView
                android:id="@+id/txt_nombre_moto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Yamaha MT-07"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@+id/img_moto"
                app:layout_constraintTop_toTopOf="@+id/img_moto" />

            <TextView
                android:id="@+id/txt_placa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Placa: ABC-123"
                android:textColor="@color/gris_hint"
                app:layout_constraintStart_toStartOf="@+id/txt_nombre_moto"
                app:layout_constraintTop_toBottomOf="@+id/txt_nombre_moto" />

            <TextView
                android:id="@+id/txt_estado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/boton_redondo"
                android:backgroundTint="#2E7D32"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Al día"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@+id/txt_placa"
                app:layout_constraintTop_toBottomOf="@+id/txt_placa" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/button_garaje_volver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/button_blue"
        android:text="Volver al Inicio"
        android:textColor="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
