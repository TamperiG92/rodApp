<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Cerrar" />

    <TextView
        android:id="@+id/title_mantenimiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nueva Tarea"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_close" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_guardar"
        app:layout_constraintTop_toBottomOf="@+id/title_mantenimiento">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETALLES GENERALES"
                android:textColor="@color/gris_hint"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_tipo_mantenimiento"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/texto_usuario" />

            <EditText
                android:id="@+id/et_fecha"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/texto_usuario"
                android:hint="10/27/2023"
                android:paddingStart="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gris_hint"
                android:drawableStart="@android:drawable/ic_menu_my_calendar"
                android:drawablePadding="12dp"
                app:drawableTint="@color/gris_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="KILOMETRAJE"
                android:textColor="@color/gris_hint"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_km_mantenimiento"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/texto_usuario"
                android:hint="Ej. 12,500 km"
                android:paddingStart="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gris_hint" />

            <EditText
                android:id="@+id/et_repetir"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/texto_usuario"
                android:hint="Repetir cada (ej. 3000) km"
                android:paddingStart="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gris_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="DETALLES ADICIONALES"
                android:textColor="@color/gris_hint"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_notas"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/texto_usuario"
                android:gravity="top"
                android:hint="Marca de aceite, costo, nombre del taller, observaciones..."
                android:padding="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gris_hint" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_guardar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:text="Guardar Mantenimiento"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:backgroundTint="@color/button_blue"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
