<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101F22">

    <View
        android:id="@+id/bg_blur_top"
        android:layout_width="256dp"
        android:layout_height="256dp"
        android:background="@drawable/bg_blur_subtle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="80dp"
        android:translationY="-80dp" />

    <View
        android:id="@+id/bg_blur_bottom"
        android:layout_width="256dp"
        android:layout_height="256dp"
        android:background="@drawable/bg_blur_subtle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-80dp"
        android:translationY="80dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:maxWidth="480dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout
                android:id="@+id/icon_container"
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0.3"
                app:layout_constraintBottom_toTopOf="@+id/heading_container">

                <View
                    android:layout_width="128dp"
                    android:layout_height="128dp"
                    android:layout_gravity="center"
                    android:background="@drawable/icon_glow_effect" />

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/shape_circle_cyan_border">

                    <ImageView
                        android:layout_width="35.8dp"
                        android:layout_height="27.3dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_mark"
                        app:tint="#11B4D4" />
                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/heading_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingBottom="16dp"
                app:layout_constraintTop_toBottomOf="@id/icon_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="273dp"
                    android:layout_height="wrap_content"
                    android:text="@string/cuenta_creada"
                    android:textColor="#11B4D4"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:letterSpacing="-0.025"
                    android:fontFamily="@font/inter_bold" />
            </LinearLayout>

            <TextView
                android:layout_width="255dp"
                android:layout_height="wrap_content"
                android:text="Descripción del éxito o mensaje de bienvenida"
                android:textColor="#94A3B8"
                android:textSize="18sp"
                android:textAlignment="center"
                android:lineSpacingExtra="11dp"
                app:layout_constraintTop_toBottomOf="@id/heading_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp"
            android:gap="16dp">

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continuar"
                android:textColor="#101F22"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="999dp"
                app:backgroundTint="#11B4D4"
                android:textAllCaps="false"
                app:icon="@drawable/ic_arrow_right"
                app:iconGravity="textEnd"
                app:iconTint="#101F22" />

            <Button
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Regresar al inicio"
                android:textColor="#94A3B8"
                android:textSize="16sp"
                android:textAllCaps="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>