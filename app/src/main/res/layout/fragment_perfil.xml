<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="100dp">

        <!-- Top Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btn_back_perfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_light" />

            <TextView
                android:id="@+id/title_config"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/title_configuracion"
                android:textColor="@color/text_light"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_guardar_perfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/btn_guardar"
                android:textColor="@color/cyan_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Avatar & Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_foto_perfil"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:strokeWidth="0dp">

                    <!-- Default Avatar placeholder -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/text_gray" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Camera badge -->
                <ImageView
                    android:id="@+id/fab_camera_perfil"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="@drawable/design_snackbar_background"
                    android:backgroundTint="@color/cyan_primary"
                    app:tint="@color/black_background"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txt_nombre_perfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/perfil_nombre_placeholder"
                android:textColor="@color/text_light"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_directions"
                    app:tint="@color/cyan_primary"/>

                <TextView
                    android:id="@+id/txt_moto_perfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/perfil_moto_placeholder"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- SECTIONS GENERATOR MACRO (Simulated for brevity with Cards) -->

        <!-- CUENTA -->
        <TextView
            style="@style/SectionHeaderStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_cuenta"
            android:textColor="@color/text_dark_slate"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Fila Correo -->
                <LinearLayout
                    android:id="@+id/row_correo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/sym_action_email" app:tint="@color/cyan_primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_correo" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/perfil_email_placeholder" android:textColor="@color/text_gray" android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_flecha_derecha" android:textColor="@color/text_gray" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" 
                    android:background="@color/surface_stroke" android:layout_marginStart="56dp"/>

                <!-- Fila Contraseña -->
                <LinearLayout
                    android:id="@+id/row_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_secure" app:tint="@color/cyan_primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_pass" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_actualizada_3m" android:textColor="@color/text_gray" android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_flecha_derecha" android:textColor="@color/text_gray" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- NOTIFICACIONES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_notificaciones_push"
            android:textColor="@color/text_dark_slate"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Push -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_popup_reminder" app:tint="@color/cyan_primary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="16dp"
                        android:text="@string/label_notif_push" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_push" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" 
                    android:background="@color/surface_stroke" android:layout_marginStart="56dp"/>

                <!-- Alertas Mantenimiento -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_preferences" app:tint="@color/cyan_primary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="16dp"
                        android:text="@string/label_alertas_mantenimiento" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_alerts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PREFERENCIAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_preferencias"
            android:textColor="@color/text_dark_slate"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Unidades -->
                <LinearLayout
                    android:id="@+id/row_unidades"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_compass" app:tint="@color/cyan_primary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="16dp"
                        android:text="@string/label_unidades" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/label_unidades_km_full" android:textColor="@color/text_gray" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_flecha_derecha" android:textColor="@color/text_gray" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" 
                    android:background="@color/surface_stroke" android:layout_marginStart="56dp"/>

                <!-- Tema -->
                <LinearLayout
                    android:id="@+id/row_tema"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_day" app:tint="@color/cyan_primary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="16dp"
                        android:text="@string/label_tema" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/label_sistema" android:textColor="@color/text_gray" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_flecha_derecha" android:textColor="@color/text_gray" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SEGURIDAD -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_seguridad"
            android:textColor="@color/text_dark_slate"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_secure" app:tint="@color/cyan_primary" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_biometria" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_biometria_desc" android:textColor="@color/text_gray" android:textSize="12sp"/>
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_biometria" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="false"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AYUDA Y SOPORTE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_ayuda_soporte"
            android:textColor="@color/text_dark_slate"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Preguntas -->
                <LinearLayout
                    android:id="@+id/row_faq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_help" app:tint="@color/cyan_primary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="16dp"
                        android:text="@string/label_faq" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_directions" app:tint="@color/text_gray" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" 
                    android:background="@color/surface_stroke" android:layout_marginStart="56dp"/>

                <!-- Contacto -->
                <LinearLayout
                    android:id="@+id/row_contacto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/sym_action_call" app:tint="@color/cyan_primary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="16dp"
                        android:text="@string/label_contacto" android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_flecha_derecha" android:textColor="@color/text_gray" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Cerrar Sesión Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_logout"
            android:textAllCaps="false"
            android:textColor="@color/maint_orange"
            android:textSize="16sp"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconGravity="textStart"
            app:iconTint="@color/maint_orange"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/maint_orange"
            app:strokeWidth="1dp"
            app:cornerRadius="30dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
