<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="190dp"
    android:background="@color/dark_blue"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <!-- Foto de perfil circular con borde azul -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardBackgroundColor="@color/background_blue"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/button_blue"
        app:strokeWidth="2dp">

        <ImageView
            android:id="@+id/img_perfil_header"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/logo"
            android:contentDescription="Foto de perfil del usuario" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/txt_nombre_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="Usuario RodApp"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txt_correo_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="usuario@rodapp.com"
        android:textColor="@color/gris_hint"
        android:textSize="14sp" />

</LinearLayout>
