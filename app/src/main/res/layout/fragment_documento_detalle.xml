<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="60dp">

        <!-- Top Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btn_back_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_light" />

            <TextView
                android:id="@+id/title_detail_doc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Detalle de Documento"
                android:textColor="@color/text_light"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Document Super Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header (Fake Image Placeholder) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:background="#132328"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="12dp">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_secure"
                        app:tint="@color/cyan_primary"
                        android:background="@drawable/design_snackbar_background"
                        android:backgroundTint="#0C2529" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="SEGURO OBLIGATORIO"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:letterSpacing="0.05"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Document Body Details -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_doc_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SOAT"
                        android:textColor="@color/text_light"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Active Badge Pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/design_snackbar_background"
                        android:backgroundTint="#0A3A40"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_doc_title">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/design_snackbar_background"
                            android:backgroundTint="#4CAF50" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Activo"
                            android:textColor="#4CAF50"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_doc_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Moto Yamaha MT-03"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_doc_title" />

                    <!-- Divider -->
                    <View
                        android:id="@+id/divider_doc"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/surface_stroke"
                        app:layout_constraintTop_toBottomOf="@id/tv_doc_subtitle" />

                    <!-- Póliza Number -->
                    <TextView
                        android:id="@+id/lbl_poliza"
                        style="@style/SectionHeaderStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="NÚMERO DE PÓLIZA"
                        android:textColor="@color/cyan_primary"
                        android:textSize="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider_doc" />

                    <TextView
                        android:id="@+id/tv_poliza_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="1234-5678-90"
                        android:textColor="@color/text_light"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lbl_poliza" />

                    <ImageView
                        android:id="@+id/btn_copy"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_crop"
                        app:tint="@color/text_gray"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_poliza_id"
                        app:layout_constraintTop_toTopOf="@+id/tv_poliza_id" />

                    <!-- Aseguradora -->
                    <TextView
                        android:id="@+id/lbl_aseguradora"
                        style="@style/SectionHeaderStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="ASEGURADORA"
                        android:textColor="@color/cyan_primary"
                        android:textSize="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_poliza_id" />
                        
                    <LinearLayout
                        android:id="@+id/ll_aseguradora"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        app:layout_constraintTop_toBottomOf="@id/lbl_aseguradora">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_dialog_map"
                            android:background="@drawable/design_snackbar_background"
                            android:backgroundTint="@color/text_light"
                            android:padding="6dp"
                            app:tint="@color/black_background" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Seguros del Estado S.A."
                            android:textColor="@color/text_light"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Date Cards Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="24dp"
                        app:layout_constraintTop_toBottomOf="@id/ll_aseguradora">

                        <!-- Vigencia Desde -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="#132328"
                            app:cardCornerRadius="8dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Vigencia Desde"
                                    android:textColor="@color/text_gray"
                                    android:textSize="10sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="15 Ene 2024"
                                    android:textColor="@color/text_light"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Vence Card (With Cyan Line Tracker) -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardBackgroundColor="#132328"
                            app:cardCornerRadius="8dp"
                            app:strokeWidth="0dp">
                            
                            <!-- Inside fake constraint to set the Cyan Line -->
                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                
                                <View
                                    android:layout_width="3dp"
                                    android:layout_height="0dp"
                                    android:background="@color/cyan_primary"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintBottom_toBottomOf="parent"/>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingStart="15dp"
                                    android:paddingTop="12dp"
                                    android:paddingBottom="12dp"
                                    android:paddingEnd="12dp"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Vence"
                                        android:textColor="@color/cyan_primary"
                                        android:textSize="10sp" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="15 Ene 2025"
                                        android:textColor="@color/text_light"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Help Notice -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Este documento digital es válido para presentar ante las autoridades de tránsito según la resolución vigente."
            android:textColor="@color/text_dark_slate"
            android:textSize="12sp" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- Edit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edit_doc"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Editar Documento"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="@color/black"
            app:backgroundTint="@color/cyan_primary"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
