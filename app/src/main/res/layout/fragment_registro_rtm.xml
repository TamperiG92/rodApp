<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="100dp"> <!-- Ajuste de padding inferior para evitar que se corte el botón -->

        <ImageButton
            android:id="@+id/btn_back_rtm"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_back_desc"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/title_rtm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_registro_rtm"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/btn_back_rtm"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btn_back_rtm" />

        <TextView
            android:id="@+id/lbl_detalles_rtm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/lbl_detalles_doc"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_rtm" />

        <TextView
            android:id="@+id/subtitle_rtm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitle_rtm"
            android:textColor="@color/gris_hint"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_detalles_rtm" />

        <TextView
            android:id="@+id/lbl_n_certificado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/lbl_n_certificado"
            android:textColor="@color/button_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/subtitle_rtm" />

        <EditText
            android:id="@+id/et_n_certificado"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/texto_usuario"
            android:hint="@string/hint_n_poliza"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/gris_hint"
            android:inputType="number"
            android:importantForAutofill="no"
            app:layout_constraintTop_toBottomOf="@+id/lbl_n_certificado" />

        <TextView
            android:id="@+id/lbl_nombre_cda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lbl_nombre_cda"
            android:textColor="@color/button_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/et_n_certificado" />

        <EditText
            android:id="@+id/et_nombre_cda"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/texto_usuario"
            android:hint="@string/hint_cda"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/gris_hint"
            android:inputType="text"
            android:importantForAutofill="no"
            app:layout_constraintTop_toBottomOf="@+id/lbl_nombre_cda" />

        <LinearLayout
            android:id="@+id/layout_fechas_rtm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintTop_toBottomOf="@+id/et_nombre_cda">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_expedicion"
                    android:textColor="@color/button_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_expedicion_rtm"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/texto_usuario"
                    android:hint="@string/hint_fecha"
                    android:gravity="center"
                    android:focusable="false"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gris_hint"
                    android:inputType="none"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_vencimiento"
                    android:textColor="@color/button_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_vencimiento_rtm"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/texto_usuario"
                    android:hint="@string/hint_fecha"
                    android:gravity="center"
                    android:focusable="false"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gris_hint"
                    android:inputType="none"
                    android:importantForAutofill="no" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/lbl_foto_rtm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/lbl_foto_rtm"
            android:textColor="@color/button_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_fechas_rtm" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_foto_rtm"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/dark_blue"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#1F3238"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@+id/lbl_foto_rtm">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                tools:ignore="UseCompoundDrawables">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/button_blue"
                    android:contentDescription="@string/camara_desc" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/txt_subir_foto"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_formatos_foto"
                    android:textColor="@color/gris_hint"
                    android:textSize="10sp"
                    tools:ignore="SmallSp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/info_rtm_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/info_rtm"
            android:textColor="@color/gris_hint"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@+id/card_foto_rtm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_finalizar_rtm"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="@string/btn_finalizar_registro"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold"
            app:backgroundTint="@color/button_blue"
            app:cornerRadius="30dp"
            app:layout_constraintTop_toBottomOf="@+id/info_rtm_text"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
