<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Header -->
            <ImageView
                android:id="@+id/icon_garaje_header"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/primary"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/title_garaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Garaje"
                android:textColor="@color/text_secondary"
                android:textSize="20sp"
                android:fontFamily="@font/inter_bold"
                android:letterSpacing="-0.02"
                app:layout_constraintBottom_toBottomOf="@+id/icon_garaje_header"
                app:layout_constraintStart_toEndOf="@+id/icon_garaje_header"
                app:layout_constraintTop_toTopOf="@+id/icon_garaje_header" />

            <ImageView
                android:id="@+id/btn_settings_garaje"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_secondary"
                android:contentDescription="@null" />

            <!-- Section Title & Subtitle -->
            <TextView
                android:id="@+id/txt_mantento_doc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Mantén tus documentos al\ndía"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:lineHeight="32sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/title_garaje" />

            <TextView
                android:id="@+id/subtitle_doc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Rodar seguro es tu prioridad. Toca cada tarjeta\npara subir la información de tu vehículo."
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:lineHeight="22.75sp"
                android:fontFamily="sans-serif"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txt_mantento_doc" />

            <!-- Tarjeta SOAT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_soat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/surface_accent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_dark"
                app:strokeWidth="2dp"
                app:layout_constraintTop_toBottomOf="@+id/subtitle_doc">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <FrameLayout
                        android:id="@+id/icon_container_soat"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/boton_redondo"
                        android:backgroundTint="@color/surface_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="@color/primary"
                            android:contentDescription="@null" />
                    </FrameLayout>
                    
                    <TextView
                        android:id="@+id/lbl_soat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="SOAT"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:fontFamily="@font/inter_bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_container_soat"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/badge_soat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/boton_redondo"
                        android:backgroundTint="@color/surface_accent_10"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:layout_marginStart="8dp"
                        android:text="PENDIENTE"
                        android:textColor="@color/secondary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="0.05"
                        app:layout_constraintBottom_toBottomOf="@+id/lbl_soat"
                        app:layout_constraintStart_toEndOf="@+id/lbl_soat"
                        app:layout_constraintTop_toTopOf="@+id/lbl_soat" />
                    
                    <!-- Simulación de borde para el badge -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@drawable/shape_circle_cyan_border"
                        android:backgroundTint="@color/secondary"
                        app:layout_constraintBottom_toBottomOf="@+id/badge_soat"
                        app:layout_constraintEnd_toEndOf="@+id/badge_soat"
                        app:layout_constraintStart_toStartOf="@+id/badge_soat"
                        app:layout_constraintTop_toTopOf="@+id/badge_soat" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Seguro Obligatorio de Accidentes"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/lbl_soat"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_soat" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/text_primary"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="16dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/primary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:cornerRadius="16dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta RTM -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_rtm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_accent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_dark"
                app:strokeWidth="2dp"
                app:layout_constraintTop_toBottomOf="@+id/card_soat">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <FrameLayout
                        android:id="@+id/icon_container_rtm"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/boton_redondo"
                        android:backgroundTint="@color/surface_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_preferences"
                            app:tint="@color/primary"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/lbl_rtm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="RTM"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:fontFamily="@font/inter_bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_container_rtm"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/badge_rtm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/boton_redondo"
                        android:backgroundTint="@color/surface_accent_10"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:layout_marginStart="8dp"
                        android:text="PENDIENTE"
                        android:textColor="@color/secondary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="0.05"
                        app:layout_constraintBottom_toBottomOf="@+id/lbl_rtm"
                        app:layout_constraintStart_toEndOf="@+id/lbl_rtm"
                        app:layout_constraintTop_toTopOf="@+id/lbl_rtm" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Revisión Técnico-Mecánica"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/lbl_rtm"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_rtm" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/text_primary"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="16dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/primary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:cornerRadius="16dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta Añadir Otro -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_otro_doc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_dark"
                app:strokeWidth="2dp"
                app:layout_constraintTop_toBottomOf="@+id/card_rtm"
                app:layout_constraintBottom_toBottomOf="parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <FrameLayout
                        android:id="@+id/icon_container_otro"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/boton_redondo"
                        android:backgroundTint="@color/surface_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_input_add"
                            app:tint="@color/primary"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/lbl_otro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Añadir otro documento"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_container_otro"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/text_hint"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
