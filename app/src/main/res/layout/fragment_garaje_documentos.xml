<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <ImageView
                android:id="@+id/icon_garaje_header"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/button_blue"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/title_garaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Garaje"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/icon_garaje_header"
                app:layout_constraintStart_toEndOf="@+id/icon_garaje_header"
                app:layout_constraintTop_toTopOf="@+id/icon_garaje_header" />

            <ImageView
                android:id="@+id/btn_settings_garaje"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txt_mantento_doc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Mantén tus documentos al\ndía"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/title_garaje" />

            <TextView
                android:id="@+id/subtitle_doc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Rodar seguro es tu prioridad. Toca cada tarjeta para subir la información de tu vehículo."
                android:textColor="@color/gris_hint"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txt_mantento_doc" />

            <!-- Tarjeta SOAT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_soat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/dark_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#1F3238"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@+id/subtitle_doc">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/icon_soat"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/texto_usuario"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/button_blue"
                        android:contentDescription="@null" />
                    <TextView
                        android:id="@+id/lbl_soat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="SOAT"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_soat"
                        app:layout_constraintTop_toTopOf="@+id/icon_soat" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/boton_redondo"
                        android:backgroundTint="#33FF9800"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:layout_marginStart="8dp"
                        android:text="⚠ PENDIENTE"
                        android:textColor="#FF9800"
                        android:textSize="10sp"
                        app:layout_constraintBottom_toBottomOf="@+id/lbl_soat"
                        app:layout_constraintStart_toEndOf="@+id/lbl_soat"
                        app:layout_constraintTop_toTopOf="@+id/lbl_soat" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seguro Obligatorio de Accidentes"
                        android:textColor="@color/gris_hint"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/lbl_soat"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_soat" />
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/black"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="24dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/button_blue"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:cornerRadius="12dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta RTM -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_rtm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/dark_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#1F3238"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@+id/card_soat">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/icon_rtm"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/texto_usuario"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_preferences"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/button_blue"
                        android:contentDescription="@null" />
                    <TextView
                        android:id="@+id/lbl_rtm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="RTM"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_rtm"
                        app:layout_constraintTop_toTopOf="@+id/icon_rtm" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/boton_redondo"
                        android:backgroundTint="#33FF9800"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:layout_marginStart="8dp"
                        android:text="⚠ PENDIENTE"
                        android:textColor="#FF9800"
                        android:textSize="10sp"
                        app:layout_constraintBottom_toBottomOf="@+id/lbl_rtm"
                        app:layout_constraintStart_toEndOf="@+id/lbl_rtm"
                        app:layout_constraintTop_toTopOf="@+id/lbl_rtm" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Revisión Técnico-Mecánica"
                        android:textColor="@color/gris_hint"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/lbl_rtm"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_rtm" />
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/black"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="24dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/button_blue"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:cornerRadius="12dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta Añadir Otro -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_otro_doc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/dark_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#1F3238"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@+id/card_rtm"
                app:layout_constraintBottom_toBottomOf="parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/icon_otro"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/texto_usuario"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_input_add"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/button_blue"
                        android:contentDescription="@null" />
                    <TextView
                        android:id="@+id/lbl_otro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Añadir otro documento"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_otro"
                        app:layout_constraintTop_toTopOf="@+id/icon_otro" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personaliza tus registros"
                        android:textColor="@color/gris_hint"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/lbl_otro"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_otro" />
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/black"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="24dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/button_blue"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:cornerRadius="12dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
