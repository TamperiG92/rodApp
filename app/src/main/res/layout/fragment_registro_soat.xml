<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="100dp">

        <ImageButton
            android:id="@+id/btn_close_soat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="@string/btn_close_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/title_soat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_registro_soat"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/btn_close_soat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btn_close_soat" />

        <!-- Icono central del SOAT -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_icon_soat_header"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/dark_blue"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#1F3238"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_soat">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/button_blue"
                    android:contentDescription="@null" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="#FF9800"
                    android:contentDescription="@null" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/lbl_n_poliza"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/lbl_n_poliza"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_icon_soat_header" />

        <EditText
            android:id="@+id/et_n_poliza"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/white"
            android:hint="@string/hint_n_poliza"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/black"
            android:textColorHint="@color/gris_hint"
            android:inputType="number"
            android:importantForAutofill="no"
            app:layout_constraintTop_toBottomOf="@+id/lbl_n_poliza" />

        <TextView
            android:id="@+id/lbl_aseguradora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lbl_aseguradora"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/et_n_poliza" />

        <Spinner
            android:id="@+id/spinner_aseguradora"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/texto_usuario"
            app:layout_constraintTop_toBottomOf="@+id/lbl_aseguradora" />

        <LinearLayout
            android:id="@+id/layout_fechas_soat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintTop_toBottomOf="@+id/spinner_aseguradora">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_inicio_vigencia"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/et_inicio_soat"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="8dp"
                    android:background="@android:color/white"
                    android:hint="@string/hint_fecha"
                    android:gravity="center"
                    android:focusable="false"
                    android:textColor="@color/black"
                    android:textColorHint="@color/gris_hint"
                    android:inputType="none"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_vencimiento"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/et_vencimiento_soat"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="8dp"
                    android:background="@android:color/white"
                    android:hint="@string/hint_fecha"
                    android:gravity="center"
                    android:focusable="false"
                    android:textColor="@color/black"
                    android:textColorHint="@color/gris_hint"
                    android:inputType="none"
                    android:importantForAutofill="no" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_info_soat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#1A00BCD4"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@+id/layout_fechas_soat">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                tools:ignore="UseCompoundDrawables">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="@color/button_blue"
                    android:contentDescription="@null" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/info_soat"
                    android:textColor="@color/gris_hint"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardar_soat"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="@string/btn_guardar_doc"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"
            app:backgroundTint="@color/dark_blue"
            app:cornerRadius="12dp"
            app:strokeColor="#1F3238"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@+id/card_info_soat" />

        <TextView
            android:id="@+id/txt_paso_soat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/paso_soat"
            android:textColor="@color/gris_hint"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_guardar_soat" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
